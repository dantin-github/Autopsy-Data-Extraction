# -------------------------------------------------------
# Build output
# -------------------------------------------------------
build/
dist/
nbproject/private/

# -------------------------------------------------------
# Patch working directories (generated by build-patch-core.bat)
# -------------------------------------------------------
patch/work/
patch/inspect/
patch/manifest-check/
patch/org-sleuthkit-autopsy-core-patched.jar

# The original Autopsy core JAR is copyrighted Sleuth Kit software
# and must NOT be distributed.  Obtain it from your Autopsy installation.
patch/core.jar

# -------------------------------------------------------
# Temporary backup directories created during development
# -------------------------------------------------------
tmp_bak/
tmp_bak2/
# Top-level /org/ is an extracted-classes artefact, not source
/org/

# -------------------------------------------------------
# Java compiled classes (anywhere in tree)
# -------------------------------------------------------
*.class

# -------------------------------------------------------
# Build and install scripts (local machine specific)
# -------------------------------------------------------
*.bat

# -------------------------------------------------------
# Blockchain module (local certs and build output)
# -------------------------------------------------------
blockchain/target/
blockchain/conf/

# -------------------------------------------------------
# Local toolchain (e.g. Apache Maven unpacked under /tools)
# -------------------------------------------------------
tools/apache-maven-*/

# -------------------------------------------------------
# API gateway: local chain certs (from npm run copy-chain-certs)
# -------------------------------------------------------
api-gateway/conf/sdk.key
api-gateway/conf/sdk.crt
api-gateway/conf/ca.crt
api-gateway/conf/fisco-config.json
api-gateway/conf/accounts/*.pem

# Local npm tarball / scratch (do not commit)
api-gateway/fisco-bcos-*.tgz
api-gateway/package/

# -------------------------------------------------------
# Cursor
# -------------------------------------------------------
.cursor/

# Local HTTP session / cookies (never commit)
judge-cookies.txt

# Ephemeral E2E OTP payload (expires; do not commit)
api-gateway/e2e-police-otp-body.json

# -------------------------------------------------------
# IDE / OS artefacts
# -------------------------------------------------------
.DS_Store
Thumbs.db
*.iml
.idea/
.vscode/
nbproject/private/
