PORT=3000
NODE_ENV=development

# When 1/true (default in non-production): before listen, run `node scripts/seed-roles.js --ensure`
# so users missing onchainAddress / keystore are registered. Set to 0 in production unless you intend it.
# AUTO_SEED_ROLES=1

# /__throw, /__police-only, /__judge-only are registered when NODE_ENV is not production,
# or when ENABLE_DEBUG_ROUTES=1 (e.g. if you must use NODE_ENV=production locally).
# ENABLE_DEBUG_ROUTES=1

# Judge dashboard (redirect after judge login). Must be a valid URL.
JUDGE_DASHBOARD_URL=http://localhost:8501

# Required. Used by express-session in later stages; gateway refuses to start if unset.
# Generate e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace-with-a-long-random-string

# Optional: data/audit-address-aliases.json — object mapping "0x"+40 hex keys to Caller labels
# for old audit rows after re-seeding keys (see users.json formerOnchainAddresses).
#
# Optional: judge/police session cookie lifetime in ms (default: 7200000 = 2 hours).
# With rolling: true, each authenticated request resets this idle window.
# SESSION_MAX_AGE_MS=7200000
#
# Dev note: sessions live in the gateway process memory by default. Restarting the
# API gateway clears every login immediately (Cookie still sent but server has no data → 401).

# Optional: override path to users.json (default: ./data/users.json). Create with: npm run seed-users
# USERS_FILE=data/users.json

# Optional: full case records JSON map (default: ~/.case_record_store.json). Same as Java CaseRecordStore.
# RECORD_STORE_PATH=~/.case_record_store.json

# FISCO BCOS Node SDK config (default: ./conf/fisco-config.json). Create with: npm run copy-chain-certs
# Then copy a console account PEM to conf/accounts/gateway.pem
# FISCO_CONFIG=./conf/fisco-config.json

# On-chain user table for hash-only rows (default: t_case_hash). Must match chain DDL.
# CASE_HASH_TABLE=t_case_hash

# CaseRegistry.sol address after: npm run deploy-contract (S5.1).
# CASE_REGISTRY_ADDR=0x0000000000000000000000000000000000000000

# S6.1: crud = only t_case_hash insert; contract = also CaseRegistry.createRecord (needs signingPassword when addr set).
# CHAIN_MODE=crud

# Legacy: same as contract path when CASE_REGISTRY_ADDR set (prefer CHAIN_MODE=contract).
# UPLOAD_USE_CASE_REGISTRY=1

# Phase 8: CaseRegistry event log → data/audit.jsonl (see README Phase 8).
# AUDIT_LOG_PATH=./data/audit.jsonl
# AUDIT_STATE_PATH=./data/audit-state.json
# EVENT_LISTENER_POLL_MS=5000
# ENABLE_EVENT_LISTENER=1

# Optional: pino level (trace|debug|info|warn|error|fatal)
# LOG_LEVEL=info

# After /login, email OTP is accepted as X-Auth-Token for this long (ms).
# Default 7200000 = 2 hours (suits slow exports). Tighten e.g. 600000 = 10 min; lengthen e.g. 28800000 = 8 h.
# OTP_TTL_MS=7200000

# Email: set MAIL_DRY_RUN=1 during dev to log OTP in server output without SMTP.
# MAIL_DRY_RUN=1
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Case Gateway <no-reply@example.com>"
