PORT=3000
NODE_ENV=development

# Required. Used by express-session in later stages; gateway refuses to start if unset.
# Generate e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace-with-a-long-random-string

# Optional: override path to users.json (default: ./data/users.json). Create with: npm run seed-users
# USERS_FILE=data/users.json

# Optional: pino level (trace|debug|info|warn|error|fatal)
# LOG_LEVEL=info
