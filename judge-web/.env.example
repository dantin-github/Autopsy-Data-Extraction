# Run from this folder so Streamlit loads .streamlit/config.toml (theme + no email prompt):
#   .\run-dashboard.ps1
# Or: python -m streamlit run app.py --server.port 8501
# (On Windows, `streamlit` alone may fail if Python Scripts is not on PATH; prefer -m or the script.)
# If you still see "Email:" in the terminal, run once: .\scripts\ensure-streamlit-credentials.ps1
# PORT=8501

# API Gateway base URL (used from Phase S1.2 onward)
API_GATEWAY_URL=http://localhost:3000

# Optional: trace|debug|info|warn|error
LOG_LEVEL=info

# Optional: default case ID for Query tab placeholder and smoke tests (S3.x / S6.x)
SMOKE_CASE_ID=e2e-1776665697937
